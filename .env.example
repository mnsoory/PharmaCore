# PharmaCore - Local Environment Variables Template
# Copy this file to '.env' and change the secrets before running the containers.

# Database
DB_NAME=PharmaCore
DB_SA_PASSWORD=YourStrongPassword123! # Ensure it meets SQL Server complexity policy

# JWT Settings
JWT_SECRET=your-super-secret-key-at-least-32-chars-long
JWT_ISSUER=PharmaCore
JWT_AUDIENCE=PharmaCore
JWT_EXPIRY_MINUTES=60